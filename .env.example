# UI
SCREEN_WIDTH=320
SCREEN_HEIGHT=240
FULLSCREEN=true

# Audio monitoring
AUDIO_SAMPLE_RATE=48000
AUDIO_CHANNELS=1
AUDIO_BLOCK_SIZE=1024
AUDIO_INPUT_DEVICE_NAME=USB

# Live stream source for ffmpeg (Raspberry Pi ALSA device)
USB_ALSA_DEVICE=hw:1,0
FFMPEG_BIN=ffmpeg

# HLS stream server
HLS_HTTP_PORT=9000
HLS_SEGMENT_SECONDS=1
HLS_BITRATE=128k

# Cast discovery
GOOGLE_GROUPS_ONLY=true
CAST_DISCOVERY_TIMEOUT=12
# Optional: comma-separated IPs if mDNS is blocked (e.g. 192.168.1.50,192.168.1.51)
CAST_KNOWN_HOSTS=

@ -0,0 +1,43 @@
# UI
SCREEN_WIDTH=320
SCREEN_HEIGHT=240
FULLSCREEN=true
# Plate button column on TFT: left (270° rotation) or right (90°)
PLATE_BUTTONS_SIDE=left

# Remote mirror of the TFT (Raspberry Pi Connect / VNC) — see scripts/setup_rpconnect.sh
# 1 = run x11vnc on :0 to mirror exactly what's on the PiTFT
VINYL_MIRROR_VNC=0
VINYL_VNC_PORT=5900
# 1 = listen on localhost only (tunnel via Connect/SSH); 0 = expose on the LAN
VINYL_VNC_LOCALHOST=1
# Set a (simple, no-space) password when exposing on the LAN (VINYL_VNC_LOCALHOST=0)
VINYL_VNC_PASSWORD=
# Show scrolling boot progress on the TFT (1=yes, 0=off). Disable once boot is stable.
VINYL_BOOT_DEBUG=1
# Adafruit PiTFT rotation/type are applied by scripts/setup_pitft.sh (config.txt overlay),
# not here. Override at install time: PITFT_TYPE=28c PITFT_ROTATE=270 ./scripts/install_service.sh
# Flip 90<->270 to fix an upside-down panel.

# Audio monitoring
AUDIO_SAMPLE_RATE=48000
AUDIO_CHANNELS=1
AUDIO_BLOCK_SIZE=1024
AUDIO_INPUT_DEVICE_NAME=USB

# Live stream source for ffmpeg (Raspberry Pi ALSA device)
# Run: arecord -l  — use hw:<card>,0 where card matches your USB mic (often 2, not 1)
USB_ALSA_DEVICE=hw:2,0
FFMPEG_BIN=ffmpeg

# HLS stream server
HLS_HTTP_PORT=9000
HLS_SEGMENT_SECONDS=1
HLS_BITRATE=128k

# Cast discovery
GOOGLE_GROUPS_ONLY=false
CAST_DISCOVERY_TIMEOUT=16
# How often (seconds) the speaker list auto-refreshes from the background scan
CAST_REFRESH_INTERVAL=6
# Optional: comma-separated IPs if mDNS is blocked (e.g. 192.168.1.50,192.168.1.51)
CAST_KNOWN_HOSTS=
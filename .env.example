# Pi Audio Cast Display — environment defaults
#
# On the Pi (fresh SD — easiest path):
#   git clone <repo-url> ~/Desktop/vinyl && cd ~/Desktop/vinyl
#   bash scripts/setup_pi.sh              # one-shot: deps, venv, PiTFT 28r, kiosk, .env
#
# After git pull or manual tweaks:
#   cd ~/Desktop/vinyl
#   cp .env.example .env          # first time only (or merge missing keys by hand)
#   arecord -l                    # confirm USB card number → USB_ALSA_DEVICE=hw:N,0
#   bash scripts/recover.sh
#   sudo reboot
#
# Web UI (phone/browser): http://<pi-ip>:8080/

# UI
SCREEN_WIDTH=320
SCREEN_HEIGHT=240
FULLSCREEN=true
# Plate button column on TFT: left (270° rotation) or right (90°)
PLATE_BUTTONS_SIDE=left

# Remote mirror of the TFT (Raspberry Pi Connect / VNC) — see scripts/setup_rpconnect.sh
VINYL_MIRROR_VNC=0
VINYL_VNC_PORT=5900
# 1 = listen on localhost only (tunnel via Connect/SSH); 0 = expose on the LAN
VINYL_VNC_LOCALHOST=1
VINYL_VNC_PASSWORD=
# Show scrolling boot progress on the TFT (1=yes, 0=off). Disable once boot is stable.
VINYL_BOOT_DEBUG=1

# Audio — turntable/line-in via USB audio interface (sounddevice bars + ffmpeg cast)
# Find the card with `arecord -l` (USB interface is often card 2) → USB_ALSA_DEVICE=hw:N,0
# recover.sh installs ~/.asoundrc and switches this to vinyl_in (shared capture).
# Most USB interfaces are stereo line-in: AUDIO_CHANNELS=2. Test while playing a record:
#   bash scripts/test_usb_audio.sh
AUDIO_SAMPLE_RATE=48000
AUDIO_CHANNELS=2
AUDIO_BLOCK_SIZE=256
# Substring match for sounddevice — "USB" matches most interfaces; or use a brand name from arecord -l
AUDIO_INPUT_DEVICE_NAME=USB
USB_ALSA_DEVICE=hw:2,0
FFMPEG_BIN=ffmpeg

# Cast stream (Pi → Chromecast) — lossless PCM/WAV by default for lowest lag + best quality
HLS_HTTP_PORT=9000
# Used only for lossy codecs (aac/mp3). Lossless wav/flac ignore this.
HLS_BITRATE=256k
# Auto-calibrate on boot when missing or clipping (writes ~/.vinyl/calibration.json)
VINYL_AUTO_CALIBRATE=1
# Optional overrides — leave unset to use calibration.json values:
# CAST_INPUT_GAIN_DB=-9
# CAST_OUTPUT_VOLUME=1.0
# CAST_HIGH_CUT_HZ=16000
# CAST_EQ_BASS_DB=4
# CAST_EQ_TREBLE_DB=2.5
# CAST_STEREO_MODE=stereo
# Profile presets (explicit CAST_* keys below override the profile when set):
#   live       — wav PCM + gentle EQ, smallest buffers (default)
#   hifi       — flac lossless + gentle EQ
#   compatible — mp3 fallback for picky speakers
CAST_STREAM_PROFILE=live
CAST_LOW_LATENCY=1
CAST_FFMPEG_QUEUE_SIZE=64
CAST_RTBUFSIZE=16k
CAST_STREAM_CODEC=wav
CAST_STREAM_EQ=1
# ffmpeg EQ when CAST_STREAM_EQ=1 (0 = off that band)
CAST_EQ_BASS_DB=4
CAST_EQ_TREBLE_DB=2.5
# stereo | duplicate | duplicate_r | swap | sum — or from calibration.json
CAST_STEREO_MODE=stereo
# ALSA dsnoop tuning (applied by setup_usb_capture.sh / recover.sh)
VINYL_ALSA_PERIOD_SIZE=128
VINYL_ALSA_BUFFER_SIZE=512
# Bar meter — trim matches cast gain; auto-range uses a rolling min–max window
AUDIO_LEVEL_INPUT_TRIM_DB=
AUDIO_LEVEL_AUTO_RANGE=1
AUDIO_LEVEL_AUTO_DECAY=0.993
AUDIO_LEVEL_FLOOR_DB=-58
AUDIO_LEVEL_CEIL_DB=6
AUDIO_LEVEL_GAIN=1.0

# Web interface — same controls as the TFT (installable as a PWA on your phone)
VINYL_WEB_UI=1
VINYL_WEB_HOST=0.0.0.0
VINYL_WEB_PORT=8080

# Auto-connect on startup (priority order; quotes required when names contain spaces)
# Empty = manual speaker selection only
VINYL_AUTO_CAST="Living Room pair"

# Cast discovery
CAST_DISCOVERY_TIMEOUT=16
CAST_REFRESH_INTERVAL=6
# Optional if mDNS is blocked: CAST_KNOWN_HOSTS=192.168.1.50,192.168.1.51
CAST_KNOWN_HOSTS=

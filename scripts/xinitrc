#!/bin/sh
# Minimal X session: only the cast app (no desktop).
APP_DIR="$(cd "$(dirname "$0")/.." && pwd)"
export DISPLAY="${DISPLAY:-:0}"
export HOME="${HOME:-/home/vinyl}"
export XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}"

if ! "$APP_DIR/scripts/start_app.sh"; then
  echo "start_app.sh failed — check venv and journalctl -u pi-audio-cast-display" >&2
  sleep 15
  exit 1
fi
